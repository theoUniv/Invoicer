// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum DocumentStatus {
  uploaded
  processed
  validated
  rejected

  @@map("documents_status")
}

enum CompanyRelationType {
  emitter
  recipient
  subject

  @@map("document_company_links_relation_type")
}

enum FieldValidationStatus {
  valid
  invalid
  unchecked

  @@map("document_fields_validation_status")
}

model DocumentType {
  documentTypeId Int       @id @default(autoincrement()) @map("document_type_id")
  name           String    @db.VarChar(100)
  description    String?   @db.Text

  documents      Document[]

  @@map("document_types")
}

model Company {
  companyId  Int      @id @default(autoincrement()) @map("company_id")
  siret      String   @db.Char(14)
  name       String   @db.VarChar(255)
  tvaNumber  String?  @map("tva_number") @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at")

  documentLinks DocumentCompanyLink[]

  @@unique([siret], map: "uq_companies_siret")
  @@map("companies")
}

model Role {
  roleId      Int     @id @default(autoincrement()) @map("role_id")
  name        String  @db.VarChar(50)
  description String? @db.Text

  users User[]

  @@unique([name], map: "uq_roles_name")
  @@map("roles")
}

model User {
  userId       Int      @id @default(autoincrement()) @map("user_id")
  roleId       Int      @map("role_id")
  email        String   @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  firstName    String?  @map("first_name") @db.VarChar(100)
  lastName     String?  @map("last_name") @db.VarChar(100)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  lastLoginAt  DateTime? @map("last_login_at")

  role Role @relation(fields: [roleId], references: [roleId], onUpdate: Cascade, onDelete: Restrict)

  uploadedDocuments  Document[]        @relation("DocumentsUploadedBy")
  processedVersions  DocumentVersion[] @relation("VersionsProcessedBy")
  validatedFields    DocumentField[]   @relation("FieldsValidatedBy")

  @@unique([email], map: "uq_users_email")
  @@map("users")
}

model Document {
  documentId     Int            @id @default(autoincrement()) @map("document_id")
  documentTypeId Int            @map("document_type_id")
  originalName   String         @map("original_name") @db.VarChar(255)
  storagePath    String         @map("storage_path") @db.VarChar(500)
  uploadedAt     DateTime       @default(now()) @map("uploaded_at")
  uploadedBy     Int?           @map("uploaded_by")
  status         DocumentStatus @default(uploaded)

  documentType DocumentType @relation(fields: [documentTypeId], references: [documentTypeId], onUpdate: Cascade, onDelete: Restrict)
  uploader     User?        @relation("DocumentsUploadedBy", fields: [uploadedBy], references: [userId], onUpdate: Cascade, onDelete: SetNull)

  versions      DocumentVersion[]
  companyLinks  DocumentCompanyLink[]

  @@map("documents")
}

model DocumentVersion {
  versionId     Int      @id @default(autoincrement()) @map("version_id")
  documentId    Int      @map("document_id")
  versionNumber Int      @default(1) @map("version_number")
  ocrText       String?  @map("ocr_text") @db.LongText
  extractedAt   DateTime @default(now()) @map("extracted_at")
  processedBy   Int?     @map("processed_by")

  document    Document @relation(fields: [documentId], references: [documentId], onUpdate: Cascade, onDelete: Cascade)
  processor   User?    @relation("VersionsProcessedBy", fields: [processedBy], references: [userId], onUpdate: Cascade, onDelete: SetNull)

  fields      DocumentField[]

  @@map("document_versions")
}

model DocumentCompanyLink {
  linkId       Int                 @id @default(autoincrement()) @map("link_id")
  documentId   Int                 @map("document_id")
  companyId    Int                 @map("company_id")
  relationType CompanyRelationType @map("relation_type")

  document Document @relation(fields: [documentId], references: [documentId], onUpdate: Cascade, onDelete: Cascade)
  company  Company  @relation(fields: [companyId], references: [companyId], onUpdate: Cascade, onDelete: Restrict)

  @@map("document_company_links")
}

model DocumentField {
  fieldId           Int                  @id @default(autoincrement()) @map("field_id")
  versionId         Int                  @map("version_id")
  fieldName         String               @map("field_name") @db.VarChar(100)
  fieldValue        String?              @map("field_value") @db.VarChar(255)
  validationStatus  FieldValidationStatus @default(unchecked) @map("validation_status")
  validatedBy       Int?                 @map("validated_by")
  validatedAt       DateTime?            @map("validated_at")

  version    DocumentVersion @relation(fields: [versionId], references: [versionId], onUpdate: Cascade, onDelete: Cascade)
  validator  User?           @relation("FieldsValidatedBy", fields: [validatedBy], references: [userId], onUpdate: Cascade, onDelete: SetNull)

  @@map("document_fields")
}
